{
  "name": "taverntones",
  "version": "1.0.0",
  "main": "src/backend/core/main.js",
  "scripts": {
    "start": "electron .",
    "json": "electron . --tool=gamify",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "CrispyChestnuts",
  "license": "ISC",
  "description": "TavernTones is a bot designed to help CrispyChestnuts stream licensed ambient soundscapes and background music during TTRPG sessions hosted remotely on Discord.",
  "dependencies": {
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "@discordjs/voice": "^0.17.0",
    "axios": "^1.7.9",
    "discord.js": "^14.16.1",
    "electron-store": "^11.0.0",
    "ffmpeg": "^0.0.4",
    "opusscript": "^0.0.8",
    "tweetnacl": "^1.0.3",
    "wav-encoder": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^32.0.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.CrispyChestnuts.TavernTones",
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "forceCodeSigning": false,
      "artifactName": "TavernTones.exe"
    },
    "files": [
      "src/",
      "package.json",
      "resources/MobRules/MobRules.png"
    ],
    "extraResources": [],
    "directories": {
      "output": "build"
    },
    "publish": null
  }
}