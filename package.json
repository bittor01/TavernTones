{
  "name": "taverntones",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "json": "electron . --tool=gamify"
  },
  "keywords": [],
  "author": "CrispyChestnuts",
  "license": "ISC",
  "description": "TavernTones is a bot designed to help CrispyChestnuts stream licensed ambient soundscapes and background music during TTRPG sessions hosted remotely on Discord.",
  "dependencies": {
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "@discordjs/voice": "^0.17.0",
    "axios": "^1.7.9",
    "discord.js": "^14.16.1",
    "dotenv": "^16.4.5",
    "ffmpeg": "^0.0.4",
    "opusscript": "^0.0.8",
    "tweetnacl": "^1.0.3",
    "wav-encoder": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^32.0.1"
  },
  "build": {
    "appId": "com.CrispyChestnuts.TavernTones",
    "files": [
      "environmentvars.env",
      "src/main.js",
      "src/ui/preload.js",
      "index.html",
      "src/ui/renderer.js",
      "styles.css"
    ],
    "directories": {
      "output": "build"
    }
  }
}
